<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_slagalica_blue"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvNotificationsHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/notifications_title"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnOpenFilterMenu"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/master_symbol_btn_bg"
            android:gravity="center"
            android:text="⇅"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnTestChat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:minWidth="0dp"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="@string/notifications_test_chat"
                android:textAllCaps="false"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnTestRanking"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:minWidth="0dp"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="@string/notifications_test_ranking"
                android:textAllCaps="false"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnTestReward"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:minWidth="0dp"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="@string/notifications_test_rewards"
                android:textAllCaps="false"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnTestOther"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="@string/notifications_test_other"
                android:textAllCaps="false"
                android:textSize="16sp" />
        </LinearLayout>
    </HorizontalScrollView>

    <TextView
        android:id="@+id/tvNotificationsEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/notifications_empty"
        android:textSize="18sp"
        android:visibility="gone" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/notificationsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

</LinearLayout>
