<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_slagalica_blue"
    android:fillViewport="true"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvConnectionsRound"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/app_on_surface"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvConnectionsCurrentPlayer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="#1C3E63"
            android:textSize="17sp" />

        <TextView
            android:id="@+id/tvConnectionsPhaseInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#2A4F75"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvConnectionsTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/app_on_surface"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvConnectionsScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#1C3E63"
            android:textSize="17sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/connections_left_title"
                android:textColor="@color/app_on_surface"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/connections_right_title"
                android:textColor="@color/app_on_surface"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <Button
                    android:id="@+id/btnLeft1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/connections_item_bg"
                    android:backgroundTint="@null"
                    android:textAllCaps="false"
                    android:textColor="@color/app_on_surface"
                    android:textSize="16sp" />

                <Button
                    android:id="@+id/btnLeft2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/connections_item_bg"
                    android:backgroundTint="@null"
                    android:textAllCaps="false"
                    android:textColor="@color/app_on_surface"
                    android:textSize="16sp" />

                <Button
                    android:id="@+id/btnLeft3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/connections_item_bg"
                    android:backgroundTint="@null"
                    android:textAllCaps="false"
                    android:textColor="@color/app_on_surface"
                    android:textSize="16sp" />

                <Button
                    android:id="@+id/btnLeft4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/connections_item_bg"
                    android:backgroundTint="@null"
                    android:textAllCaps="false"
                    android:textColor="@color/app_on_surface"
                    android:textSize="16sp" />

                <Button
                    android:id="@+id/btnLeft5"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/connections_item_bg"
                    android:backgroundTint="@null"
                    android:textAllCaps="false"
                    android:textColor="@color/app_on_surface"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <Button
                    android:id="@+id/btnRight1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/connections_item_bg"
                    android:backgroundTint="@null"
                    android:textAllCaps="false"
                    android:textColor="@color/app_on_surface"
                    android:textSize="16sp" />

                <Button
                    android:id="@+id/btnRight2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/connections_item_bg"
                    android:backgroundTint="@null"
                    android:textAllCaps="false"
                    android:textColor="@color/app_on_surface"
                    android:textSize="16sp" />

                <Button
                    android:id="@+id/btnRight3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/connections_item_bg"
                    android:backgroundTint="@null"
                    android:textAllCaps="false"
                    android:textColor="@color/app_on_surface"
                    android:textSize="16sp" />

                <Button
                    android:id="@+id/btnRight4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/connections_item_bg"
                    android:backgroundTint="@null"
                    android:textAllCaps="false"
                    android:textColor="@color/app_on_surface"
                    android:textSize="16sp" />

                <Button
                    android:id="@+id/btnRight5"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/connections_item_bg"
                    android:backgroundTint="@null"
                    android:textAllCaps="false"
                    android:textColor="@color/app_on_surface"
                    android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnConnectionsContinue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/connections_open_next_phase"
            android:textSize="18sp" />
    </LinearLayout>
</ScrollView>
