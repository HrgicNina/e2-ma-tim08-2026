<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_slagalica_blue"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvUnsupportedGameLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sledeca igra"
            android:textColor="@color/app_on_surface"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvUnsupportedGameTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/app_primary_blue"
            android:textSize="34sp"
            android:textStyle="bold" />
    </LinearLayout>

</FrameLayout>
