<?xml version="1.0" encoding="utf-8"?>
<ScrollView android:background="@drawable/bg_slagalica_blue" xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvStepRound"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:textStyle="bold"
            android:textSize="28sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/match_header_panel_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvHeaderLeftAvatar"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/profile_avatar_bg"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="@color/app_on_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvHeaderLeftName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:maxWidth="96dp"
                        android:singleLine="true"
                        android:textColor="#EAF4FF"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvHeaderLeftScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvStepTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:textColor="#FFFFFF"
                android:textSize="31sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end|center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:gravity="end"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvHeaderRightName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:maxWidth="96dp"
                        android:singleLine="true"
                        android:textColor="#EAF4FF"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvHeaderRightScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvHeaderRightAvatar"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/profile_avatar_bg"
                    android:gravity="center"
                    android:text="2"
                    android:textColor="@color/app_on_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvStepCurrentPlayer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvStepPhaseInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:visibility="gone"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvStepScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textStyle="bold"
            android:textSize="12sp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/stepCluesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvStepClue1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:background="@drawable/step_clues_panel_bg"
                android:padding="10dp"
                android:textColor="@color/app_on_primary"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tvStepClue2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:background="@drawable/step_clues_panel_bg"
                android:padding="10dp"
                android:textColor="@color/app_on_primary"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tvStepClue3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:background="@drawable/step_clues_panel_bg"
                android:padding="10dp"
                android:textColor="@color/app_on_primary"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tvStepClue4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:background="@drawable/step_clues_panel_bg"
                android:padding="10dp"
                android:textColor="@color/app_on_primary"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tvStepClue5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:background="@drawable/step_clues_panel_bg"
                android:padding="10dp"
                android:textColor="@color/app_on_primary"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tvStepClue6"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:background="@drawable/step_clues_panel_bg"
                android:padding="10dp"
                android:textColor="@color/app_on_primary"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tvStepClue7"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/step_clues_panel_bg"
                android:padding="10dp"
                android:textColor="@color/app_on_primary"
                android:textSize="20sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvStepSolution"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/step_clues_panel_bg"
            android:padding="10dp"
            android:textColor="@color/app_on_primary"
            android:textSize="20sp" />

        <EditText
            android:id="@+id/etStepAnswer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/step_answer_hint"
            android:inputType="text"
            android:textSize="20sp" />

        <Button
            android:id="@+id/btnStepSubmit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/step_submit"
            android:textSize="20sp" />

    </LinearLayout>
</ScrollView>
