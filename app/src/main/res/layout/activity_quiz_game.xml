<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_slagalica_blue"
    android:fillViewport="true"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvQuizQuestionIndex"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/app_on_surface"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvQuizCurrentPlayer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:visibility="gone"
            android:textColor="@color/app_on_surface"
            android:textSize="17sp" />

        <TextView
            android:id="@+id/tvQuizPhaseInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:visibility="gone"
            android:textColor="@color/app_on_surface"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvQuizTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/app_on_surface"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvQuizScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/app_on_surface"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/quiz_question_label"
            android:textColor="@color/app_on_surface"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvQuizQuestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/profile_card_bg"
            android:padding="16dp"
            android:textColor="@color/app_on_surface"
            android:textSize="22sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnQuizAnswer1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/quiz_answer_default_bg"
            android:backgroundTint="@null"
            android:textAllCaps="false"
            android:textColor="@color/app_on_surface"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnQuizAnswer2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/quiz_answer_default_bg"
            android:backgroundTint="@null"
            android:textAllCaps="false"
            android:textColor="@color/app_on_surface"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnQuizAnswer3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/quiz_answer_default_bg"
            android:backgroundTint="@null"
            android:textAllCaps="false"
            android:textColor="@color/app_on_surface"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnQuizAnswer4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/quiz_answer_default_bg"
            android:backgroundTint="@null"
            android:textAllCaps="false"
            android:textColor="@color/app_on_surface"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnQuizNext"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/quiz_next_question"
            android:textSize="18sp" />
    </LinearLayout>
</ScrollView>
