<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_slagalica_blue"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <ProgressBar
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:indeterminate="true" />

        <TextView
            android:id="@+id/tvMatchInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/match_waiting"
            android:textColor="@color/app_on_surface"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:alpha="0"
        android:importantForAccessibility="no"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvMatchStage"
            android:layout_width="1dp"
            android:layout_height="1dp" />

        <TextView
            android:id="@+id/tvMatchScore"
            android:layout_width="1dp"
            android:layout_height="1dp" />

        <TextView
            android:id="@+id/tvMatchTokens"
            android:layout_width="1dp"
            android:layout_height="1dp" />

        <TextView
            android:id="@+id/tvMatchStars"
            android:layout_width="1dp"
            android:layout_height="1dp" />

        <TextView
            android:id="@+id/tvMatchLeague"
            android:layout_width="1dp"
            android:layout_height="1dp" />

        <TextView
            android:id="@+id/tvMatchGame1"
            android:layout_width="1dp"
            android:layout_height="1dp" />

        <TextView
            android:id="@+id/tvMatchGame2"
            android:layout_width="1dp"
            android:layout_height="1dp" />

        <TextView
            android:id="@+id/tvMatchGame3"
            android:layout_width="1dp"
            android:layout_height="1dp" />

        <TextView
            android:id="@+id/tvMatchGame4"
            android:layout_width="1dp"
            android:layout_height="1dp" />

        <TextView
            android:id="@+id/tvMatchGame5"
            android:layout_width="1dp"
            android:layout_height="1dp" />

        <TextView
            android:id="@+id/tvMatchGame6"
            android:layout_width="1dp"
            android:layout_height="1dp" />

        <EditText
            android:id="@+id/etInviteTarget"
            android:layout_width="1dp"
            android:layout_height="1dp" />

        <Button
            android:id="@+id/btnMatchOpenGame"
            android:layout_width="1dp"
            android:layout_height="1dp" />

        <Button
            android:id="@+id/btnMatchNextGame"
            android:layout_width="1dp"
            android:layout_height="1dp" />

        <Button
            android:id="@+id/btnSubmitMatchScore"
            android:layout_width="1dp"
            android:layout_height="1dp" />

        <Button
            android:id="@+id/btnFindRandom"
            android:layout_width="1dp"
            android:layout_height="1dp" />

        <Button
            android:id="@+id/btnCancelQueue"
            android:layout_width="1dp"
            android:layout_height="1dp" />

        <Button
            android:id="@+id/btnInviteFriend"
            android:layout_width="1dp"
            android:layout_height="1dp" />

        <Button
            android:id="@+id/btnMatchGiveUp"
            android:layout_width="1dp"
            android:layout_height="1dp" />
    </LinearLayout>

</FrameLayout>
