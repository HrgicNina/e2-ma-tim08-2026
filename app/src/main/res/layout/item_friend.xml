<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/profile_card_bg"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <TextView
        android:id="@+id/tvFriendAvatar"
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:background="@drawable/profile_avatar_bg"
        android:gravity="center"
        android:text="🦉"
        android:textColor="@color/app_on_primary"
        android:textSize="28sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvFriendUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/app_on_surface"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvFriendMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textColor="@color/app_on_surface"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvFriendStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textColor="@color/app_on_surface"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <Button
        android:id="@+id/btnInviteFriend"
        android:layout_width="92dp"
        android:layout_height="44dp"
        android:text="Pozovi"
        android:textSize="14sp" />
</LinearLayout>
