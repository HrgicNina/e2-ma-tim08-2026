<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_slagalica_blue"
    android:orientation="vertical"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.9"
        android:background="@drawable/profile_card_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="10dp">

        <LinearLayout
            android:layout_width="86dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvProfileAvatar"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:background="@drawable/profile_avatar_bg"
                android:gravity="center"
                android:text="🦉"
                android:textColor="#FFFFFF"
                android:textSize="34sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnAvatarChange"
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:layout_marginTop="5dp"
                android:padding="0dp"
                android:text="Avatar"
                android:textAllCaps="false"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvProfileUsername"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/profile_username_placeholder"
                android:textColor="@color/app_on_surface"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvProfileEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/app_on_surface"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvProfileRegion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/profile_region_placeholder"
                android:textColor="@color/app_on_surface"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvProfileTokens"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/profile_badge_bg"
                    android:gravity="center"
                    android:text="@string/profile_tokens_value"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvProfileStars"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/profile_badge_bg"
                    android:gravity="center"
                    android:text="@string/profile_stars_value"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvProfileLeague"
                android:layout_width="match_parent"
                android:layout_height="26dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/profile_badge_bg"
                android:gravity="center"
                android:text="@string/profile_league_value"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="86dp"
            android:layout_height="match_parent"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/qrInviteView"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:background="@drawable/profile_qr_bg"
                android:padding="5dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/profile_qr_description"
                android:textColor="@color/app_on_surface"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="2.1"
        android:background="@drawable/profile_card_bg"
        android:orientation="vertical"
        android:padding="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.92"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="94dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Pobeda"
                    android:textColor="@color/app_on_surface"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.example.slagalica.StatsCircleView
                    android:id="@+id/viewWinCircle"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:layout_marginTop="2dp" />

                <TextView
                    android:id="@+id/tvStatsTotalMatches"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="0 partija"
                    android:textColor="@color/app_on_surface"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Uspešnost po igrama"
                    android:textColor="@color/app_on_surface"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.example.slagalica.StatsBarChartView
                    android:id="@+id/viewGameBars"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:paddingStart="3dp"
                    android:paddingEnd="3dp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/gameSelectorRow"
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnStatsQuiz"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="2dp"
                android:layout_weight="1"
                android:padding="0dp"
                android:text="KZZ"
                android:textSize="10sp" />

            <Button
                android:id="@+id/btnStatsConnections"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:layout_weight="1"
                android:padding="0dp"
                android:text="Spoj"
                android:textSize="10sp" />

            <Button
                android:id="@+id/btnStatsAssociations"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:layout_weight="1"
                android:padding="0dp"
                android:text="Aso"
                android:textSize="10sp" />

            <Button
                android:id="@+id/btnStatsMaster"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:layout_weight="1"
                android:padding="0dp"
                android:text="Sko"
                android:textSize="10sp" />

            <Button
                android:id="@+id/btnStatsStep"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:layout_weight="1"
                android:padding="0dp"
                android:text="Kor"
                android:textSize="10sp" />

            <Button
                android:id="@+id/btnStatsNumber"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="2dp"
                android:layout_weight="1"
                android:padding="0dp"
                android:text="Broj"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="6dp"
            android:layout_weight="1"
            android:background="@drawable/profile_qr_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="9dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvStatsSelectedTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ko zna zna"
                    android:textColor="@color/app_on_surface"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvStatsLegend"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="4dp"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:textColor="@color/app_on_surface"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.example.slagalica.StatsPieChartView
                android:id="@+id/viewStatsPie"
                android:layout_width="130dp"
                android:layout_height="match_parent"
                android:padding="4dp" />
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btnProfileLogout"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginTop="8dp"
        android:text="@string/btn_logout"
        android:textSize="16sp" />
</LinearLayout>
