<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_slagalica_blue"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/tvMasterRound"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#0F2D4D"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvMasterCurrentPlayer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="#1C3E63"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/tvMasterPhaseInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="#2A4F75"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvMasterTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="#0F2D4D"
        android:textSize="26sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvMasterScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="#1C3E63"
        android:textSize="16sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/masterBoardContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:orientation="vertical" />

    <Button
        android:id="@+id/btnMasterSubmit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/master_submit"
        android:textSize="18sp" />

    <LinearLayout
        android:id="@+id/masterSymbolBar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:weightSum="6" />

</LinearLayout>
