<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_slagalica_blue"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:id="@+id/tvAssociationsRound"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/app_on_surface"
        android:textSize="1sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:background="@drawable/match_header_panel_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="7dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvHeaderLeftAvatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/profile_avatar_bg"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/app_on_primary"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="7dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvHeaderLeftName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:maxWidth="82dp"
                    android:singleLine="true"
                    android:textColor="#EAF4FF"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvHeaderLeftScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvAssociationsTimer"
            android:layout_width="56dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end|center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="7dp"
                android:gravity="end"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvHeaderRightName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:maxWidth="82dp"
                    android:singleLine="true"
                    android:textColor="#EAF4FF"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvHeaderRightScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvHeaderRightAvatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/profile_avatar_bg"
                android:gravity="center"
                android:text="2"
                android:textColor="@color/app_on_primary"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tvAssociationsCurrentPlayer"
        android:layout_width="wrap_content"
        android:layout_height="20dp"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical"
        android:textColor="@color/app_on_surface"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvAssociationsPhaseInfo"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvAssociationsScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/associationsBoard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:background="@drawable/profile_card_bg"
                android:orientation="vertical"
                android:padding="5dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="17dp"
                    android:text="@string/associations_column_a"
                    android:textColor="@color/app_on_surface"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Button android:id="@+id/btnA1" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="3dp" android:layout_weight="1" android:background="@drawable/associations_closed_bg" android:backgroundTint="@null" android:textAllCaps="false" android:textColor="#FFFFFF" android:textSize="11sp" />
                <Button android:id="@+id/btnA2" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="3dp" android:layout_weight="1" android:background="@drawable/associations_closed_bg" android:backgroundTint="@null" android:textAllCaps="false" android:textColor="#FFFFFF" android:textSize="11sp" />
                <Button android:id="@+id/btnA3" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="3dp" android:layout_weight="1" android:background="@drawable/associations_closed_bg" android:backgroundTint="@null" android:textAllCaps="false" android:textColor="#FFFFFF" android:textSize="11sp" />
                <Button android:id="@+id/btnA4" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="3dp" android:layout_weight="1" android:background="@drawable/associations_closed_bg" android:backgroundTint="@null" android:textAllCaps="false" android:textColor="#FFFFFF" android:textSize="11sp" />
                <EditText android:id="@+id/btnSolveA" android:layout_width="match_parent" android:layout_height="34dp" android:layout_marginTop="4dp" android:background="@drawable/associations_solution_bg" android:gravity="center" android:hint="@string/associations_column_placeholder" android:imeOptions="actionDone" android:inputType="textCapSentences" android:paddingStart="4dp" android:paddingEnd="4dp" android:singleLine="true" android:textColor="@color/app_on_surface" android:textColorHint="#527391" android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:background="@drawable/profile_card_bg"
                android:orientation="vertical"
                android:padding="5dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="17dp"
                    android:text="@string/associations_column_b"
                    android:textColor="@color/app_on_surface"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Button android:id="@+id/btnB1" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="3dp" android:layout_weight="1" android:background="@drawable/associations_closed_bg" android:backgroundTint="@null" android:textAllCaps="false" android:textColor="#FFFFFF" android:textSize="11sp" />
                <Button android:id="@+id/btnB2" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="3dp" android:layout_weight="1" android:background="@drawable/associations_closed_bg" android:backgroundTint="@null" android:textAllCaps="false" android:textColor="#FFFFFF" android:textSize="11sp" />
                <Button android:id="@+id/btnB3" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="3dp" android:layout_weight="1" android:background="@drawable/associations_closed_bg" android:backgroundTint="@null" android:textAllCaps="false" android:textColor="#FFFFFF" android:textSize="11sp" />
                <Button android:id="@+id/btnB4" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="3dp" android:layout_weight="1" android:background="@drawable/associations_closed_bg" android:backgroundTint="@null" android:textAllCaps="false" android:textColor="#FFFFFF" android:textSize="11sp" />
                <EditText android:id="@+id/btnSolveB" android:layout_width="match_parent" android:layout_height="34dp" android:layout_marginTop="4dp" android:background="@drawable/associations_solution_bg" android:gravity="center" android:hint="@string/associations_column_placeholder" android:imeOptions="actionDone" android:inputType="textCapSentences" android:paddingStart="4dp" android:paddingEnd="4dp" android:singleLine="true" android:textColor="@color/app_on_surface" android:textColorHint="#527391" android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="5dp"
            android:gravity="center"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etAssociationsFinalGuess"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/associations_solution_bg"
                android:gravity="center"
                android:hint="@string/associations_final_placeholder"
                android:imeOptions="actionDone"
                android:inputType="textCapSentences"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:singleLine="true"
                android:textColor="@color/app_on_surface"
                android:textColorHint="#527391"
                android:textSize="13sp" />

            <ImageButton
                android:id="@+id/btnAssociationsSolveFinal"
                android:layout_width="42dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:background="@drawable/associations_solution_bg"
                android:backgroundTint="@null"
                android:contentDescription="@string/associations_confirm_solution"
                android:padding="8dp"
                android:scaleType="center"
                android:src="@drawable/ic_associations_check" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:background="@drawable/profile_card_bg"
                android:orientation="vertical"
                android:padding="5dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="17dp"
                    android:text="@string/associations_column_c"
                    android:textColor="@color/app_on_surface"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Button android:id="@+id/btnC1" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="3dp" android:layout_weight="1" android:background="@drawable/associations_closed_bg" android:backgroundTint="@null" android:textAllCaps="false" android:textColor="#FFFFFF" android:textSize="11sp" />
                <Button android:id="@+id/btnC2" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="3dp" android:layout_weight="1" android:background="@drawable/associations_closed_bg" android:backgroundTint="@null" android:textAllCaps="false" android:textColor="#FFFFFF" android:textSize="11sp" />
                <Button android:id="@+id/btnC3" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="3dp" android:layout_weight="1" android:background="@drawable/associations_closed_bg" android:backgroundTint="@null" android:textAllCaps="false" android:textColor="#FFFFFF" android:textSize="11sp" />
                <Button android:id="@+id/btnC4" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="3dp" android:layout_weight="1" android:background="@drawable/associations_closed_bg" android:backgroundTint="@null" android:textAllCaps="false" android:textColor="#FFFFFF" android:textSize="11sp" />
                <EditText android:id="@+id/btnSolveC" android:layout_width="match_parent" android:layout_height="34dp" android:layout_marginTop="4dp" android:background="@drawable/associations_solution_bg" android:gravity="center" android:hint="@string/associations_column_placeholder" android:imeOptions="actionDone" android:inputType="textCapSentences" android:paddingStart="4dp" android:paddingEnd="4dp" android:singleLine="true" android:textColor="@color/app_on_surface" android:textColorHint="#527391" android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:background="@drawable/profile_card_bg"
                android:orientation="vertical"
                android:padding="5dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="17dp"
                    android:text="@string/associations_column_d"
                    android:textColor="@color/app_on_surface"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Button android:id="@+id/btnD1" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="3dp" android:layout_weight="1" android:background="@drawable/associations_closed_bg" android:backgroundTint="@null" android:textAllCaps="false" android:textColor="#FFFFFF" android:textSize="11sp" />
                <Button android:id="@+id/btnD2" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="3dp" android:layout_weight="1" android:background="@drawable/associations_closed_bg" android:backgroundTint="@null" android:textAllCaps="false" android:textColor="#FFFFFF" android:textSize="11sp" />
                <Button android:id="@+id/btnD3" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="3dp" android:layout_weight="1" android:background="@drawable/associations_closed_bg" android:backgroundTint="@null" android:textAllCaps="false" android:textColor="#FFFFFF" android:textSize="11sp" />
                <Button android:id="@+id/btnD4" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="3dp" android:layout_weight="1" android:background="@drawable/associations_closed_bg" android:backgroundTint="@null" android:textAllCaps="false" android:textColor="#FFFFFF" android:textSize="11sp" />
                <EditText android:id="@+id/btnSolveD" android:layout_width="match_parent" android:layout_height="34dp" android:layout_marginTop="4dp" android:background="@drawable/associations_solution_bg" android:gravity="center" android:hint="@string/associations_column_placeholder" android:imeOptions="actionDone" android:inputType="textCapSentences" android:paddingStart="4dp" android:paddingEnd="4dp" android:singleLine="true" android:textColor="@color/app_on_surface" android:textColorHint="#527391" android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tvAssociationsSelectedColumn"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />

    <EditText
        android:id="@+id/etAssociationsGuess"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnAssociationsSolveColumn"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvAssociationsFinalSolution"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnAssociationsContinue"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />
</LinearLayout>
