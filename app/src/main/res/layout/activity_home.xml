<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_slagalica_blue"
    android:orientation="vertical"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnOpenProfile"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/profile_avatar_bg"
            android:gravity="center"
            android:text="U"
            android:textColor="@color/app_on_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHomeUsername"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="korisnik"
            android:textColor="@color/app_on_surface"
            android:textSize="26sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/btnOpenChat"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/master_symbol_btn_bg"
            android:gravity="center"
            android:textColor="@color/app_on_primary"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/btnOpenRankings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/master_symbol_btn_bg"
            android:gravity="center"
            android:textColor="@color/app_on_primary"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/btnOpenSettings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/master_symbol_btn_bg"
            android:gravity="center"
            android:text="?"
            android:textColor="@color/app_on_primary"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/btnOpenNotifications"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/master_symbol_btn_bg"
            android:gravity="center"
            android:textColor="@color/app_on_primary"
            android:textSize="24sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/homeStatsRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="34dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvHomeTokens"
            android:layout_width="0dp"
            android:layout_height="84dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/profile_card_bg"
            android:gravity="center"
            android:text="@string/home_tokens_value"
            android:textColor="@color/app_on_surface"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHomeStars"
            android:layout_width="0dp"
            android:layout_height="84dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/profile_card_bg"
            android:gravity="center"
            android:text="@string/home_stars_value"
            android:textColor="@color/app_on_surface"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHomeLeague"
            android:layout_width="0dp"
            android:layout_height="84dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/profile_card_bg"
            android:gravity="center"
            android:text="@string/home_league_value"
            android:textColor="@color/app_on_surface"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.14" />

    <Button
        android:id="@+id/btnStartGame"
        android:layout_width="300dp"
        android:layout_height="78dp"
        android:layout_gravity="center_horizontal"
        android:text="@string/home_start_game"
        android:textSize="30sp" />

    <Button
        android:id="@+id/btnOpenRegions"
        android:layout_width="300dp"
        android:layout_height="56dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:text="@string/btn_open_regions"
        android:textSize="20sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.38" />

    <TextView
        android:id="@+id/tvFriendsLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/home_friends_label"
        android:textColor="@color/app_on_surface"
        android:textSize="26sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/friendsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnOpenFriends"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Otvori listu prijatelja"
            android:textSize="20sp" />
    </LinearLayout>

    <Button
        android:id="@+id/btnGuestRegister"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/btn_register_now"
        android:textSize="20sp"
        android:visibility="gone" />

</LinearLayout>
