<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:background="@drawable/bg_slagalica_blue" xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/welcome"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnOpenNotifications"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/master_symbol_btn_bg"
            android:gravity="center"
            android:text="🔔"
            android:textSize="22sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvGamesLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="34dp"
        android:text="@string/games_label"
        android:textSize="24sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnOpenStepByStep"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/btn_open_step_by_step"
        android:textSize="20sp" />

    <Button
        android:id="@+id/btnOpenMastermind"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/btn_open_mastermind"
        android:textSize="20sp" />

    <Button
        android:id="@+id/btnOpenMyNumber"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/btn_open_my_number"
        android:textSize="20sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/btnOpenResetPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/btn_go_reset_password"
        android:textSize="20sp" />

    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/btn_logout"
        android:textSize="20sp" />

    <Button
        android:id="@+id/btnGuestRegister"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/btn_register_now"
        android:textSize="20sp"
        android:visibility="gone" />

</LinearLayout>
