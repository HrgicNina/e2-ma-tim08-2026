<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_slagalica_blue"
    android:orientation="vertical"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnOpenProfile"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/profile_avatar_bg"
            android:gravity="center"
            android:text="U"
            android:textColor="@color/app_on_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHomeUsername"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="korisnik"
            android:textColor="@color/app_on_surface"
            android:textSize="22sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/btnOpenChat"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/master_symbol_btn_bg"
            android:gravity="center"
            android:textColor="@color/app_on_primary"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/btnOpenRankings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/master_symbol_btn_bg"
            android:gravity="center"
            android:textColor="@color/app_on_primary"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/btnOpenSettings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/master_symbol_btn_bg"
            android:gravity="center"
            android:text="?"
            android:textColor="@color/app_on_primary"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/btnOpenNotifications"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/master_symbol_btn_bg"
            android:gravity="center"
            android:textColor="@color/app_on_primary"
            android:textSize="22sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/homeStatsRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvHomeTokens"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/profile_card_bg"
            android:gravity="center"
            android:text="@string/home_tokens_value"
            android:textColor="@color/app_on_surface"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHomeStars"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/profile_card_bg"
            android:gravity="center"
            android:text="@string/home_stars_value"
            android:textColor="@color/app_on_surface"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHomeLeague"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/profile_card_bg"
            android:gravity="center"
            android:text="@string/home_league_value"
            android:textColor="@color/app_on_surface"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.25" />

    <Button
        android:id="@+id/btnStartGame"
        android:layout_width="280dp"
        android:layout_height="72dp"
        android:layout_gravity="center_horizontal"
        android:text="@string/home_start_game"
        android:textSize="24sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.75" />

    <TextView
        android:id="@+id/tvFriendsLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="26dp"
        android:text="@string/home_friends_label"
        android:textColor="@color/app_on_surface"
        android:textSize="22sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/friendsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/friendItem1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="6dp">

            <ImageView
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:background="@drawable/profile_avatar_bg"
                android:padding="6dp"
                android:src="@drawable/owl_icon" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="marko"
                android:textColor="@color/app_on_surface"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/friendItem2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="6dp">

            <ImageView
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:background="@drawable/profile_avatar_bg"
                android:padding="6dp"
                android:src="@drawable/owl_icon" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="ana"
                android:textColor="@color/app_on_surface"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/friendItem3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="6dp">

            <ImageView
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:background="@drawable/profile_avatar_bg"
                android:padding="6dp"
                android:src="@drawable/owl_icon" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="milica"
                android:textColor="@color/app_on_surface"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btnGuestRegister"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/btn_register_now"
        android:textSize="18sp"
        android:visibility="gone" />

</LinearLayout>
