<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_slagalica_blue"
    android:orientation="vertical"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/welcome"
            android:textColor="@color/app_on_surface"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnOpenProfile"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/profile_avatar_bg"
            android:gravity="center"
            android:text="M"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnOpenNotifications"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/master_symbol_btn_bg"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="22sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvHomeTokens"
            android:layout_width="0dp"
            android:layout_height="74dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/profile_card_bg"
            android:gravity="center"
            android:text="@string/home_tokens_value"
            android:textColor="@color/app_on_surface"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHomeStars"
            android:layout_width="0dp"
            android:layout_height="74dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/profile_card_bg"
            android:gravity="center"
            android:text="@string/home_stars_value"
            android:textColor="@color/app_on_surface"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHomeLeague"
            android:layout_width="0dp"
            android:layout_height="74dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/profile_card_bg"
            android:gravity="center"
            android:text="@string/home_league_value"
            android:textColor="@color/app_on_surface"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvGamesLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="@string/games_label"
        android:textColor="@color/app_on_surface"
        android:textSize="24sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnOpenQuiz"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/btn_open_quiz"
        android:textSize="20sp" />

    <Button
        android:id="@+id/btnOpenConnections"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/btn_open_connections"
        android:textSize="20sp" />

    <Button
        android:id="@+id/btnOpenStepByStep"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/btn_open_step_by_step"
        android:textSize="20sp" />

    <Button
        android:id="@+id/btnOpenMastermind"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/btn_open_mastermind"
        android:textSize="20sp" />

    <Button
        android:id="@+id/btnOpenMyNumber"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/btn_open_my_number"
        android:textSize="20sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/btnOpenResetPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/btn_go_reset_password"
        android:textSize="20sp" />

    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/btn_logout"
        android:textSize="20sp" />

    <Button
        android:id="@+id/btnGuestRegister"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/btn_register_now"
        android:textSize="20sp"
        android:visibility="gone" />

</LinearLayout>
